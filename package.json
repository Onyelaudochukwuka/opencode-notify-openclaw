{
  "name": "opencode-notify-openclaw",
  "version": "0.5.0",
  "description": "OpenCode plugin that sends notifications via Openclaw to any messaging channel",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external @opencode-ai/plugin",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "openclaw",
    "notifications"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onyelaudochukwuka/opencode-notify-openclaw.git"
  },
  "homepage": "https://github.com/onyelaudochukwuka/opencode-notify-openclaw#readme",
  "bugs": {
    "url": "https://github.com/onyelaudochukwuka/opencode-notify-openclaw/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.19"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
